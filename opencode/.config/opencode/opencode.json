{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "linux-mcp-server": {
      "type": "local",
      "command": ["/home/linuxbrew/.linuxbrew/bin/linux-mcp-server"],
      "enabled": true,
      "environment": {
        "LOG_LEVEL": "info"
      }
    },
    "dosu": {
      "type": "remote",
      "url": "https://api.dosu.dev/v1/mcp",
      "enabled": true,
      "headers": {
        "X-Deployment-ID": "83775020-c22e-485a-a222-987b2f5a3823"
      }
    }
  }
}
